# DepthIndex Environment Variables
# Copy to .env and fill in your values (optional)

# Cloud AI Provider
# VITE_DEPTHINDEX_CLOUD_PROVIDER=gemini
# VITE_DEPTHINDEX_CLOUD_API_KEY=your-api-key-here
# VITE_DEPTHINDEX_CLOUD_MODEL=gemini-1.5-flash

# Site URL (for SEO)
# VITE_DEPTHINDEX_SITE_URL=https://your-docs.example.com

# Google Site Verification
# VITE_DEPTHINDEX_GOOGLE_VERIFICATION=your-code
