# VITE_DEPTHINDEX_CLOUD_PROVIDER=gemini
# VITE_DEPTHINDEX_CLOUD_API_KEY=your-api-key
# VITE_DEPTHINDEX_CLOUD_MODEL=gemini-1.5-flash

# Site URL (for SEO)
# VITE_DEPTHINDEX_SITE_URL=https://your-docs.example.com
